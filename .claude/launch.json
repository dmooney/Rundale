{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "apps/ui",
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "parish-web",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "source $HOME/.cargo/env && cargo run -- --web"],
      "port": 3001
    },
    {
      "name": "parish-e2e",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "source $HOME/.cargo/env && cargo run -- --web 3099"],
      "port": 3099
    }
  ]
}
