{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-dev",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "cd ui && PATH=/usr/local/Cellar/node/25.8.1_1/bin:$PATH npx vite dev"],
      "port": 5173
