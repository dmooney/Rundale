{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/PreToolUse--protect-files.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/PreToolUse--weekday-commit-block.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/PostToolUse--auto-fmt.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/PostToolUse--compile-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/PostToolUse--dep-audit-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/Stop--quality-gates.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/Stop--harness-reminder.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/Stop--doc-staleness.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/Stop--screenshot-reminder.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/Stop--coverage-reminder.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/Stop--design-doc-reminder.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/SessionStart--compact-context.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/UserPromptSubmit--commit-msg-check.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/Notification--notify.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/SubagentStart--tauri-server-check.sh"
          }
        ]
      }
    ]
  }
}
