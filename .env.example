# Parish — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.
# See docs/design/configuration.md for full reference.

# =============================================================
# Base provider (used for all categories unless overridden)
# =============================================================

# Provider: ollama (default), openrouter, lmstudio, custom
PARISH_PROVIDER=openrouter

# API key (required for openrouter)
PARISH_API_KEY=

# Model name (required for non-ollama providers)
# See https://openrouter.ai/models for available models
# Free-tier models have ":free" suffix
PARISH_MODEL=google/gemma-3-1b-it:free

# Base URL override (optional — defaults are set per provider)
# PARISH_BASE_URL=https://openrouter.ai/api

# =============================================================
# Per-category overrides (optional)
# Uncomment and set to route specific tasks to different providers.
# Unset categories inherit from the base settings above.
# =============================================================

# --- Dialogue (player NPC conversation, streamed) ---
# PARISH_DIALOGUE_PROVIDER=openrouter
# PARISH_DIALOGUE_MODEL=anthropic/claude-sonnet-4
# PARISH_DIALOGUE_API_KEY=sk-or-...
# PARISH_DIALOGUE_BASE_URL=

# --- Simulation (background NPC ticks, JSON) ---
# PARISH_SIMULATION_PROVIDER=ollama
# PARISH_SIMULATION_MODEL=qwen3:4b
# PARISH_SIMULATION_API_KEY=
# PARISH_SIMULATION_BASE_URL=

# --- Intent (player input parsing, JSON, low-latency) ---
# PARISH_INTENT_PROVIDER=ollama
# PARISH_INTENT_MODEL=qwen3:1.7b
# PARISH_INTENT_API_KEY=
# PARISH_INTENT_BASE_URL=
